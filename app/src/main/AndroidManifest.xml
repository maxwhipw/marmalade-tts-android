<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Foreground service (synthesis playback) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      INTERNET is used exclusively for engine model downloads via
      EngineInstaller. No telemetry, no analytics, no other network use.
      See PRIVACY.md / SECURITY.md for details. The set of hosts contacted
      is enumerated in EngineCatalog (currently: huggingface.co only).
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Per-app voice routing (Settings → "Per-app voices") enumerates the
      device's launchable apps so the user can pick one. Android 11+
      requires explicit visibility declarations to see other packages;
      we limit ourselves to apps that have a LAUNCHER category (UI apps
      the user could conceivably invoke TTS from), which is the minimal
      query Google Play's "permission for less" review considers
      acceptable. We do NOT request QUERY_ALL_PACKAGES — that would
      flag the listing for additional review and we don't need it.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name="app.marmalade.tts.MarmaladeTtsApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MarmaladeTts">

        <!--
          Main Activity. Doubles as the engine's CONFIGURE_ENGINE target so
          the cog next to "Marmalade TTS" in Android's TTS picker opens our
          settings UI. The DEFAULT category is required for the implicit
          intent the framework dispatches.
        -->
        <activity
            android:name="app.marmalade.tts.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MarmaladeTts">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.speech.tts.engine.CONFIGURE_ENGINE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
          System TTS engine — registered so Android Settings can select it.
          The DEFAULT category on TTS_SERVICE is required: Android enumerates
          engines via an implicit intent and won't see a service that lacks
          DEFAULT. (We learned this the hard way — see v0.1.15 release notes.)
        -->
        <service
            android:name="app.marmalade.tts.service.MarmaladeTtsService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_TEXT_TO_SPEECH_SERVICE">
            <intent-filter>
                <action android:name="android.intent.action.TTS_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech.tts"
                android:resource="@xml/tts_engine" />
        </service>

        <!--
          CHECK_TTS_DATA — Android invokes this activity to confirm voice
          data is present before listing the engine in the picker. We
          report installed voices by querying VoiceMetaDao; if none are
          installed we still return RESULT_OK but with an empty available
          list, which is sufficient for the engine to be listed (the user
          can then install voices via Marmalade's own UI).
        -->
        <activity
            android:name="app.marmalade.tts.service.CheckVoiceDataActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.speech.tts.engine.CHECK_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
          GET_SAMPLE_TEXT — returns the string the Settings picker reads
          aloud when the user taps "Play". No UI; finishes itself.
        -->
        <activity
            android:name="app.marmalade.tts.service.GetSampleTextActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.speech.tts.engine.GET_SAMPLE_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Foreground synthesis service (long-form playback) -->
        <service
            android:name="app.marmalade.tts.service.MarmaladeSynthService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!--
          Share-sheet target + system text-selection "Process text" action.
          Themed translucent so the trampoline activity never paints UI;
          it just dispatches to MarmaladeSynthService and finishes.
        -->
        <activity
            android:name="app.marmalade.tts.ui.intent.ShareIntentActivity"
            android:exported="true"
            android:label="@string/share_to_marmalade_tts"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!--
          Quick Settings tile that speaks the current clipboard. Declared
          as an ACTIVE_TILE so we can refresh icon/label as state changes.
          This tile requires the device to be unlocked: Android 10+ blocks
          background clipboard reads from a locked context, so declaring
          UNLOCK_REQUIRED=false would only get us an empty clip.
        -->
        <service
            android:name="app.marmalade.tts.service.SpeakClipboardTileService"
            android:exported="true"
            android:icon="@drawable/mascot_happy"
            android:label="@string/quick_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="false" />
        </service>

    </application>

</manifest>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Foreground service (synthesis playback) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Declared but not yet requested at runtime — voice cloning is v0.4 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!--
      INTERNET is used exclusively for engine model downloads via
      EngineInstaller. No telemetry, no analytics, no other network use.
      See PRIVACY.md / SECURITY.md for details. The set of hosts contacted
      is enumerated in EngineCatalog (currently: huggingface.co only).
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name="app.marmalade.tts.MarmaladeTtsApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MarmaladeTts">

        <!-- Main Activity -->
        <activity
            android:name="app.marmalade.tts.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MarmaladeTts">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- System TTS engine — registered so Android Settings can select it -->
        <service
            android:name="app.marmalade.tts.service.MarmaladeTtsService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_TEXT_TO_SPEECH_SERVICE">
            <intent-filter>
                <action android:name="android.intent.action.TTS_SERVICE" />
            </intent-filter>
            <meta-data
                android:name="android.speech.tts"
                android:resource="@xml/tts_engine" />
        </service>

        <!-- Foreground synthesis service (long-form playback) -->
        <service
            android:name="app.marmalade.tts.service.MarmaladeSynthService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!--
          Share-sheet target + system text-selection "Process text" action.
          Themed translucent so the trampoline activity never paints UI;
          it just dispatches to MarmaladeSynthService and finishes.
        -->
        <activity
            android:name="app.marmalade.tts.ui.intent.ShareIntentActivity"
            android:exported="true"
            android:label="@string/share_to_marmalade_tts"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!--
          Quick Settings tile that speaks the current clipboard. Declared
          as an ACTIVE_TILE so we can refresh icon/label as state changes.
          This tile requires the device to be unlocked: Android 10+ blocks
          background clipboard reads from a locked context, so declaring
          UNLOCK_REQUIRED=false would only get us an empty clip.
        -->
        <service
            android:name="app.marmalade.tts.service.SpeakClipboardTileService"
            android:exported="true"
            android:icon="@drawable/mascot_happy"
            android:label="@string/quick_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="false" />
        </service>

    </application>

</manifest>
